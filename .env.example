# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
# Modern publishable key (preferred). Used by lib/supabase-server.ts as primary,
# and by lib/supabase.ts as fallback when NEXT_PUBLIC_SUPABASE_ANON_KEY is absent.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here
# Legacy anon key (optional). Used by lib/supabase.ts as primary if present.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Add any additional environment variables below:
